{
  "name": "@ctxr/{{name}}",
  "version": "1.0.0",
  "description": "{{description}}",
  "type": "module",
  "license": "{{license}}",
  "files": [
    "ctxr-{{name}}.md",
    "README.md",
    "LICENSE"
  ],
  "ctxr": {
    "type": "output-style",
    "target": "file"
  },
  "keywords": [
    "ctxr",
    "claude-code",
    "output-style"
  ],
  "scripts": {
    "validate": "npx @ctxr/kit validate",
    "lint": "markdownlint-cli2 '**/*.md' '#node_modules'",
    "lint:fix": "markdownlint-cli2 --fix '**/*.md' '#node_modules'",
    "prepare": "husky || true"
  },
  "devDependencies": {
    "husky": "^9.1.0",
    "markdownlint-cli2": "^0.14.0"
  }
}
